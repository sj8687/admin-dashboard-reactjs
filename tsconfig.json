{
  "compilerOptions": {
    "baseUrl": "./src", // <- important
    "paths": {
      "@/*": ["*"]      // <- maps "@/..." to "src/..."
    },
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node",
    "jsx": "preserve",
    "strict": true,
    "esModuleInterop": true
  },
  "include": ["src"]
}